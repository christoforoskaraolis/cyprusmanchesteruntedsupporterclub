# DATABASE_URL alone is enough for: npm run migrate
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=verify-full
AUTH_JWT_SECRET=replace_with_a_long_random_secret
PUBLIC_APP_URL=https://your-website-url
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Cyprus MU Supporters <no-reply@your-domain.com>